# Server
PORT=3100
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://lango:lango@localhost:5435/lango?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6381

# Meta WhatsApp Cloud API — app-level secret shared by every provider="meta" integration
WHATSAPP_APP_SECRET=

# Evolution API (self-hosted) — base URL and global admin key, shared by every
# provider="evolution" integration
EVOLUTION_API_URL=http://localhost:8083
EVOLUTION_API_KEY=lango-evolution-key

# Base URL the Evolution container uses to reach this service's webhook.
# Defaults to host.docker.internal:$PORT, which works out of the box when
# Evolution runs in Docker on the same machine as lango (local dev). Override
# only if lango and Evolution run on different hosts.
EVOLUTION_WEBHOOK_BASE_URL=

# Public HTTPS base URL for this service (e.g. a cloudflared tunnel) — required
# to verify Twilio webhook signatures
PUBLIC_WEBHOOK_BASE_URL=
